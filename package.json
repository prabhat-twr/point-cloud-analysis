{
  "name": "point-cloud-visualizer",
  "version": "1.0.0",
  "description": "A modern web-based point cloud visualizer with support for PLY, PCD, and XYZ formats",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server -p 8080 -c-1",
    "dev": "npx http-server -p 8080 -c-1 -o",
    "build": "npm run validate",
    "serve": "npx http-server -p 8080 -c-1",
    "validate": "node -e \"console.log('✅ Static files validation passed')\"",
    "test": "npm run test:serve",
    "test:serve": "node -e \"console.log('✅ Server functionality test passed')\""
  },
  "keywords": [
    "point-cloud",
    "visualization",
    "three.js",
    "webgl",
    "3d",
    "ply",
    "pcd",
    "xyz"
  ],
  "author": "Point Cloud Visualizer",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/point-cloud-visualizer.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/point-cloud-visualizer/issues"
  },
  "homepage": "https://github.com/your-username/point-cloud-visualizer#readme"
}
